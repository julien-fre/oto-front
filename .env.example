# Config publique frontend (copier en .env.local pour le dev local)
NEXT_PUBLIC_LOGTO_ENDPOINT=https://auth.oto.ninja
# Client SPA Logto — pré-créé via la Management API (cf. skill logto-client côté oto-dashboard)
NEXT_PUBLIC_LOGTO_APP_ID=
# Audience = API resource d'oto-mcp (le backend). mcp.oto.ninja = preprod (ADR 0040)
NEXT_PUBLIC_LOGTO_AUDIENCE=https://mcp.oto.ninja/mcp
NEXT_PUBLIC_OTO_MCP_BASE=https://mcp.oto.ninja
