# Config publique frontend (copier en .env.local pour le dev local — jamais commit).
# Must run on port 5192 (`npm run dev` already does this) — the Logto SPA client
# below only has http://localhost:5192/callback registered as a redirect URI.
NEXT_PUBLIC_LOGTO_ENDPOINT=https://auth.oto.ninja
# Client SPA Logto partagé avec oto-dashboard (pas de client dédié pour l'instant).
NEXT_PUBLIC_LOGTO_APP_ID=fpnoljbmz81o3t07plb4c
# PROD (mcp.oto.cx), pas preprod : mcp.oto.ninja a un CORS cassé (aucun header
# Access-Control-Allow-Origin sur le preflight, vérifié 2026-07-23) — à corriger
# côté oto-backend avant de repointer dessus.
NEXT_PUBLIC_LOGTO_AUDIENCE=https://mcp.oto.cx/mcp
NEXT_PUBLIC_OTO_MCP_BASE=https://mcp.oto.cx
